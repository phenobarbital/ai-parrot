<form class="form-layout--{{ layout_class }} max-w-2xl mx-auto space-y-6" id="{{ form.form_id }}" method="post">
{%- if resolve(form.title) %}
  <h2 class="form-title text-2xl font-bold text-gray-900">{{ resolve(form.title) }}</h2>
{%- endif %}
{%- if form.description and resolve(form.description) %}
  <p class="form-description text-sm text-gray-500 mt-1">{{ resolve(form.description) }}</p>
{%- endif %}
{%- for section in form.sections %}
  <fieldset class="form-section border border-gray-200 rounded-lg p-5 space-y-4" id="section-{{ section.section_id }}"
    {%- if section.depends_on %} data-depends-on="{{ section.depends_on.model_dump_json() }}"{% endif %}>
    {%- if section.title and resolve(section.title) %}
    <legend class="form-section__title text-lg font-semibold text-gray-800 px-2">{{ resolve(section.title) }}</legend>
    {%- endif %}
    {%- if section.description and resolve(section.description) %}
    <p class="form-section__description text-sm text-gray-500">{{ resolve(section.description) }}</p>
    {%- endif %}
    <div class="form-section__fields space-y-4">
    {%- for field in section.fields %}
      {{ render_field(field) | safe }}
    {%- endfor %}
    </div>
  </fieldset>
{%- endfor %}
  <div class="form-actions flex items-center gap-3 pt-4">
    <button type="submit" class="form-actions__submit inline-flex items-center px-5 py-2.5 bg-blue-600 text-white font-medium text-sm rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors">{{ submit_label }}</button>
{%- if form.cancel_allowed %}
    <button type="button" class="form-actions__cancel inline-flex items-center px-5 py-2.5 bg-white text-gray-700 font-medium text-sm rounded-lg border border-gray-300 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-300 focus:ring-offset-2 transition-colors">{{ cancel_label }}</button>
{%- endif %}
  </div>
</form>
