<!DOCTYPE html>
<html lang="{{ locale }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
  <title>{{ form_title }}</title>
  <script src="https://telegram.org/js/telegram-web-app.js"></script>
  <style>
    :root {
      --bg: var(--tg-theme-bg-color, #fff);
      --text: var(--tg-theme-text-color, #1a1a2e);
      --hint: var(--tg-theme-hint-color, #999);
      --link: var(--tg-theme-link-color, #0066cc);
      --btn-bg: var(--tg-theme-button-color, #0066cc);
      --btn-text: var(--tg-theme-button-text-color, #fff);
      --secondary-bg: var(--tg-theme-secondary-bg-color, #f4f4f5);
      --radius: 8px;
    }
    *, *::before, *::after { box-sizing: border-box; }
    body {
      font-family: -apple-system, system-ui, sans-serif;
      margin: 0; padding: 1rem;
      background: var(--bg); color: var(--text);
      line-height: 1.5; font-size: 15px;
    }
    .form-field { margin-bottom: 1rem; }
    .form-field label { display: block; font-weight: 600; margin-bottom: .25rem; font-size: 14px; }
    .form-field__help { display: block; font-size: .85rem; color: var(--hint); margin-bottom: .25rem; }
    .form-field__error { display: block; color: #c00; font-size: .85rem; margin-top: .25rem; }
    input, select, textarea {
      width: 100%; padding: .6rem .75rem;
      border: 1px solid var(--hint); border-radius: var(--radius);
      font: inherit; background: var(--bg); color: var(--text);
    }
    input:focus, select:focus, textarea:focus {
      outline: none; border-color: var(--btn-bg);
      box-shadow: 0 0 0 2px rgba(0,102,204,.15);
    }
    textarea { min-height: 80px; resize: vertical; }
    .form-section { border: none; padding: 0; margin: 0 0 1rem; }
    .form-section__title { font-size: 16px; font-weight: 700; margin-bottom: .5rem; }
    .form-actions { display: none; }
    .form-title { font-size: 18px; font-weight: 700; margin: 0 0 .5rem; }
    .form-description { font-size: 14px; color: var(--hint); margin: 0 0 1rem; }
    .tg-error-banner {
      background: #ffe6e6; border: 1px solid #c00;
      padding: .75rem; border-radius: var(--radius);
      margin-bottom: 1rem; color: #c00; font-size: 14px;
    }
    .form-field__radio-group { display: flex; flex-direction: column; gap: .5rem; }
    .form-field__radio-label { display: flex; align-items: center; gap: .5rem; font-weight: 400; }
    .form-field__checkbox-label { display: flex; align-items: center; gap: .5rem; font-weight: 400; }
    input[type="checkbox"], input[type="radio"] { width: auto; }
  </style>
</head>
<body>
  <div id="form-container">
    {{ form_html | safe }}
  </div>
  <div id="error-container"></div>

  <script>
    const tg = window.Telegram.WebApp;
    tg.ready();
    tg.expand();

    // Show main button as submit
    tg.MainButton.setText('Submit');
    tg.MainButton.show();

    const FORM_ID = '{{ form_id }}';
    const FALLBACK_URL = '{{ fallback_url }}';
    const MAX_SEND_DATA = 4096;

    function collectFormData() {
      const form = document.querySelector('form');
      if (!form) return {};
      const fd = new FormData(form);
      const data = {_form_id: FORM_ID};
      for (const [key, value] of fd.entries()) {
        if (key in data && Array.isArray(data[key])) {
          data[key].push(value);
        } else if (key in data) {
          data[key] = [data[key], value];
        } else {
          data[key] = value;
        }
      }
      // Handle unchecked checkboxes
      form.querySelectorAll('input[type=checkbox]').forEach(cb => {
        if (!fd.has(cb.name)) data[cb.name] = false;
      });
      return data;
    }

    function showError(msg) {
      const c = document.getElementById('error-container');
      c.innerHTML = '<div class="tg-error-banner">' + msg + '</div>';
    }

    tg.MainButton.onClick(async function() {
      const data = collectFormData();
      const json = JSON.stringify(data);

      if (json.length <= MAX_SEND_DATA) {
        tg.sendData(json);
      } else {
        // REST fallback for large payloads
        tg.MainButton.showProgress();
        try {
          const res = await fetch(FALLBACK_URL, {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: json,
          });
          const result = await res.json();
          if (result.is_valid) {
            tg.showAlert('Form submitted successfully!', function() { tg.close(); });
          } else {
            const errors = Object.entries(result.errors || {})
              .map(([k, v]) => k + ': ' + (Array.isArray(v) ? v.join(', ') : v))
              .join('\n');
            showError(errors || 'Validation failed');
          }
        } catch (err) {
          showError('Network error: ' + err.message);
        } finally {
          tg.MainButton.hideProgress();
        }
      }
    });
  </script>
</body>
</html>
