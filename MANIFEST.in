include LICENSE
include README.md
include pyproject.toml
global-include *.typed

# Whitelist: include all packages
graft packages

# Global excludes
global-exclude *.pyc
global-exclude __pycache__
global-exclude *.so
global-exclude *.o
global-exclude .git*
global-exclude .DS_Store
global-exclude .venv
global-exclude sdd
global-exclude .env
global-exclude .claude*
global-exclude .agent*

prune settings
prune plugins/*
prune /static/*
prune */__pycache__
